# Copy to backend/.env and fill in real values. NEVER commit the real .env.
# Set ENVIRONMENT=production in production to disable the mock_test_token auth shortcut.
ENVIRONMENT=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Service-role key bypasses RLS — keep it server-side only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Clerk
CLERK_SECRET_KEY=sk_test_your_clerk_secret
CLERK_JWKS_URL=https://your-clerk-subdomain.clerk.accounts.dev/.well-known/jwks.json

# OpenRouter (AI)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
AI_MODEL=google/gemini-2.5-flash:free
